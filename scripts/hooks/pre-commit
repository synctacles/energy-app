#!/bin/bash
# Pre-commit hook to prevent hardcoded database credentials
# Blocks commits containing credential patterns that would bypass centralized config

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

BLOCKED=0

# Check staged files for hardcoded credentials
STAGED_FILES=$(git diff --cached --name-only)

echo "Checking ${#STAGED_FILES[@]} staged files for hardcoded credentials..."

for FILE in $STAGED_FILES; do
    # Skip non-text files
    if ! file "$FILE" | grep -q "text"; then
        continue
    fi

    # Check for hardcoded "synctacles@" (the bad pattern)
    if git diff --cached "$FILE" | grep -E '^\+.*synctacles@'; then
        echo -e "${RED}✗ BLOCKED: Hardcoded credentials in $FILE${NC}"
        echo "  Found pattern: synctacles@"
        echo "  Use: from config.settings import DATABASE_URL"
        BLOCKED=1
    fi

    # Check for hardcoded postgresql:// URLs
    if git diff --cached "$FILE" | grep -E '^\+.*postgresql://[a-z_]+@'; then
        echo -e "${RED}✗ BLOCKED: Hardcoded PostgreSQL URL in $FILE${NC}"
        echo "  Found pattern: postgresql://user@"
        echo "  Use: from config.settings import DATABASE_URL"
        BLOCKED=1
    fi

    # Check for os.getenv with default DATABASE_URL (anti-pattern)
    if git diff --cached "$FILE" | grep -E "os\.getenv.*DATABASE_URL.*postgresql://"; then
        echo -e "${RED}✗ BLOCKED: os.getenv with hardcoded fallback in $FILE${NC}"
        echo "  Found pattern: os.getenv('DATABASE_URL', 'postgresql://...')"
        echo "  Use: from config.settings import DATABASE_URL"
        BLOCKED=1
    fi
done

if [ $BLOCKED -eq 1 ]; then
    echo ""
    echo -e "${RED}Commit BLOCKED. Fix credential patterns and try again.${NC}"
    exit 1
fi

echo -e "${GREEN}✓ Credentials check passed${NC}"
exit 0
