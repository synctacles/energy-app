# Claude Code Ignore File
# Files and directories listed here will not be read by Claude Code

# =============================================================================
# CREDENTIALS & SECRETS
# =============================================================================

# Environment files
.env*
!.env.example
*.env
*.env.*

# Secret files
*.key
*.pem
*.p12
*.pfx
*.cer
*.crt
credentials.json
secrets.yaml
secrets.yml
secrets/
.secrets/

# SSH keys
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub
id_ecdsa
id_ecdsa.pub
id_dsa
id_dsa.pub
*.ppk

# API keys and tokens
.token
*.token
api_key.txt
.api_key

# Configuration with credentials
config/.env*
/opt/synctacles/config/

# =============================================================================
# LOGS & TEMPORARY FILES
# =============================================================================

# Log files
*.log
logs/
*.log.*
/tmp/*.log
/var/log/

# Temporary files
*.tmp
*.temp
.cache/
tmp/
temp/

