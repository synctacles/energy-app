# SYNCTACLES Development Environment
# Copy this to .env and fill in your values
#
# Requirements: All Python dependencies are in repo root:
#   - requirements.txt      (main dependencies)
#   - requirements-base.txt (base/extra dependencies)

# Database
DATABASE_URL=postgresql://synctacles@localhost:5432/synctacles

# ENTSO-E API (get from: https://transparency.entsoe.eu)
ENTSO_E_API_KEY=c3eca61e-37a9-4727-bf60-83e213b22a9e

# TenneT API Configuration
TENNET_API_KEY=your-tennet-api-key-here
TENNET_API_BASE=https://api.tennet.eu  # Production
# TENNET_API_BASE=https://api.acc.tennet.eu  # Acceptance (testing)

# Application
DEBUG=True
LOG_LEVEL=DEBUG
API_HOST=127.0.0.1
API_PORT=8000

# Log directory (used by collectors/importers)
SYNCTACLES_LOG_DIR=/opt/synctacles/logs
