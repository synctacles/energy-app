################################################################################
# ENERGY INSIGHTS NL - Environment Configuration
# Copy this to .env and fill in your values
#
# IMPORTANT: This file supports dynamic branding via environment variables.
# The setup script will use BRAND_SLUG to rename directories dynamically.
################################################################################

## BRANDING & IDENTITY (Controls all branding strings throughout the application)
# Used for display names, URLs, and Home Assistant integration
BRAND_NAME="Energy Insights NL"
BRAND_SLUG="energy-insights"
BRAND_DOMAIN="energy-insights.example.com"

# Home Assistant specific branding
HA_DOMAIN="ha_energy_insights_nl"
HA_COMPONENT_NAME="Energy Insights NL"

## DATABASE CONFIGURATION
# Main database connection
DATABASE_URL=postgresql://synctacles@localhost:5432/synctacles

# Database user/name (set by setup script, usually matches BRAND_SLUG)
DB_USER=synctacles
DB_NAME=synctacles
DB_HOST=localhost
DB_PORT=5432

## EXTERNAL API KEYS
# ENTSO-E API (get from: https://transparency.entsoe.eu)
ENTSO_E_API_KEY=c3eca61e-37a9-4727-bf60-83e213b22a9e

# TenneT API Configuration
TENNET_API_KEY=your-tennet-api-key-here
TENNET_API_BASE=https://api.tennet.eu  # Production
# TENNET_API_BASE=https://api.acc.tennet.eu  # Acceptance (testing)

## APPLICATION CONFIGURATION
DEBUG=True
LOG_LEVEL=DEBUG
API_HOST=127.0.0.1
API_PORT=8000

## INSTALLATION PATHS (Used by setup script and application)
# Base installation directory
INSTALL_PATH=/opt/energy-insights

# Application code directory
APP_PATH=/opt/energy-insights/app

# Virtual environment directory
VENV_PATH=/opt/energy-insights/venv

# Logs directory (used by collectors/importers/api)
LOG_PATH=/var/log/energy-insights

# Data directory for persistent storage
DATA_PATH=/var/lib/energy-insights

# Legacy path variable (for backwards compatibility during transition)
SYNCTACLES_LOG_DIR=/opt/energy-insights/logs

## SYSTEM USER CONFIGURATION (Set by setup script)
# Linux user that runs the services
SERVICE_USER=synctacles
SERVICE_GROUP=synctacles
SERVICE_HOME=/home/synctacles

## GIT & DEPLOYMENT
# GitHub repository URL (customize as needed)
GITHUB_REPO=git@github.com:DATADIO/ha-energy-insights-nl.git
GITHUB_REPO_DEV=/opt/github/energy-insights-repo

# Git author configuration
GIT_USER_NAME=DATADIO
GIT_USER_EMAIL=admin@datadio.nl

## SERVICE NAMES (Derived from BRAND_SLUG)
# Systemd service names (setup script will create these)
# Format: {BRAND_SLUG}-{component}.service
# Examples: energy-insights-api, energy-insights-collector, energy-insights-importer
