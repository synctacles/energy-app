################################################################################
# BRAND-FREE CONFIGURATION TEMPLATE
# Copy this to .env and fill in YOUR values
# DO NOT commit .env to git (contains your specific branding)
################################################################################

## BRANDING & IDENTITY
# Replace with your actual brand name and slug
BRAND_NAME="YOUR_BRAND_NAME"              # e.g., "Energy Insights NL"
BRAND_SLUG="your-brand-slug"               # e.g., "energy-insights"
BRAND_DOMAIN="your-domain.example.com"     # e.g., "energy-insights.io"

## GITHUB CONFIGURATION
GITHUB_ACCOUNT="YOUR_GITHUB_USERNAME"      # e.g., "your-username"
REPO_NAME="your-repo-name"                 # e.g., "ha-energy-insights-nl"
GITHUB_REPO="git@github.com:YOUR_ACCOUNT/your-repo-name.git"  # SSH clone URL
GITHUB_REPO_DEV="/opt/github/your-repo-name"  # Dev checkout location
GIT_USER_NAME="YOUR_GITHUB_USERNAME"       # Usually same as GITHUB_ACCOUNT
GIT_USER_EMAIL="your-email@example.com"    # Git author email

## HOME ASSISTANT SPECIFIC
HA_DOMAIN="your_ha_domain"                 # e.g., "ha_energy_insights_nl"
HA_COMPONENT_NAME="YOUR_BRAND_NAME"        # Usually same as BRAND_NAME

## PATH CONFIGURATION
INSTALL_PATH="/opt/your-brand-slug"        # e.g., "/opt/energy-insights"
APP_PATH="/opt/your-brand-slug/app"
LOG_PATH="/var/log/your-brand-slug"
DATA_PATH="/var/lib/your-brand-slug"

## SERVICE CONFIGURATION
SERVICE_USER="your-brand-slug"             # e.g., "energy-insights"
SERVICE_GROUP="your-brand-slug"

## DATABASE CONFIGURATION
DB_NAME="your_brand_slug"                  # e.g., "energy_insights"
DB_USER="your_brand_slug"
DB_HOST="localhost"
DB_PORT="5432"

## API CONFIGURATION
API_HOST="0.0.0.0"
API_PORT="8000"
# Leave empty to generate on first run:
ADMIN_API_KEY=""

## EXTERNAL API KEYS
# ENTSO-E API (get from: https://transparency.entsoe.eu)
ENTSO_E_API_KEY=""

# TenneT API Configuration
TENNET_API_KEY=""
TENNET_API_BASE="https://api.tennet.eu"  # Production
# TENNET_API_BASE="https://api.acc.tennet.eu"  # Acceptance (testing)

## APPLICATION CONFIGURATION
DEBUG="False"

## Logging Configuration
# Levels: off|error|warning|info|debug
# WARNING: debug generates ~1-5MB/hour, use only for troubleshooting
LOG_LEVEL=warning
LOG_PATH_FILE=/var/log/synctacles/synctacles.log
